<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Include local database and user preferences for cloud backups -->
        <include domain="database" path="finance_database"/>
        <include domain="database" path="finance_database-wal"/>
        <include domain="database" path="finance_database-shm"/>
        <include domain="sharedpref" path="security_settings.xml"/>
    </cloud-backup>
    <device-transfer>
        <!-- Enable easy device-to-device secure local transfer of user's database and state -->
        <include domain="database" path="finance_database"/>
        <include domain="database" path="finance_database-wal"/>
        <include domain="database" path="finance_database-shm"/>
        <include domain="sharedpref" path="security_settings.xml"/>
    </device-transfer>
</data-extraction-rules>
